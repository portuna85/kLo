# --- Spring profile ---
SPRING_PROFILES_ACTIVE=prod

# --- DB ---
KRAFT_DB_NAME=kraft_lotto
KRAFT_DB_URL=jdbc:mariadb://mariadb:3306/kraft_lotto
KRAFT_DB_USER=kraft
KRAFT_DB_PASSWORD=change-me
KRAFT_DB_ROOT_PASSWORD=change-me-root

# --- Admin (Basic Auth, ROLE_ADMIN) ---
# 운영(prod) 프로파일에서는 반드시 주입해야 합니다.
KRAFT_ADMIN_USERNAME=admin
KRAFT_ADMIN_PASSWORD=change-me-admin

# --- 외부 동행복권 API ---
# mock | real
KRAFT_API_CLIENT=real
KRAFT_API_URL=https://www.dhlottery.co.kr/common.do

# --- 추천 엔진 ---
KRAFT_RECOMMEND_MAX_ATTEMPTS=100000
