# ============================================================
#  KraftLotto 환경 변수 예시 (개발/로컬 실행용)
#  실제 값은 이 파일을 .env로 복사한 뒤 채워 넣으세요.
#  .env 파일에는 비밀값이 들어갈 수 있으므로 Git에 커밋하지 마세요.
#
#    cp .env.example .env
# ============================================================

# --- Spring profile ---
# 로컬 개발은 local, 운영 CD는 prod를 사용합니다.
SPRING_PROFILES_ACTIVE=local

# --- Docker Compose ports ---
KRAFT_APP_PORT=8080
KRAFT_DB_PORT=3306

# --- Database ---
# docker-compose 안에서는 DB 호스트가 mariadb 서비스명입니다.
KRAFT_DB_NAME=kraft_lotto
KRAFT_DB_URL=jdbc:mariadb://mariadb:3306/kraft_lotto?rewriteBatchedStatements=true&useUnicode=true&characterEncoding=utf8mb4&serverTimezone=Asia/Seoul&connectTimeout=3000
KRAFT_DB_USER=kraft
KRAFT_DB_PASSWORD=change-me
KRAFT_DB_ROOT_PASSWORD=change-me-root

# 호스트 OS에서 bootRun으로 직접 실행할 때 mariadb 서비스명 대신 사용할 로컬 호스트입니다.
KRAFT_DB_LOCAL_HOST=localhost
# docker-compose는 app 컨테이너에 KRAFT_IN_CONTAINER=true를 주입합니다.
# 호스트 OS에서 직접 실행할 때는 false 또는 미설정을 사용하세요.
KRAFT_IN_CONTAINER=false

# --- Lotto API ---
# local 기본값은 mock입니다. 운영 CD는 real을 주입합니다.
KRAFT_API_CLIENT=mock
KRAFT_API_URL=https://www.dhlottery.co.kr/common.do
KRAFT_API_CONNECT_TIMEOUT_MS=2000
KRAFT_API_READ_TIMEOUT_MS=3000
KRAFT_API_MAX_RETRIES=2
KRAFT_API_RETRY_BACKOFF_MS=200
KRAFT_API_FALLBACK_TO_MOCK_ON_FAILURE=true
KRAFT_API_MOCK_LATEST_ROUND=1200

# --- Admin API ---
# 관리자 API 호출 시 X-Kraft-Admin-Token 헤더에 이 값을 전달합니다.
# 운영에서는 GitHub Secrets 또는 배포 환경 변수로 별도 주입하세요.
KRAFT_ADMIN_API_TOKEN=change-me-admin-token
KRAFT_ADMIN_TOKEN_HEADER=X-Kraft-Admin-Token

# --- Scheduler / auto collect ---
KRAFT_LOTTO_SCHEDULER_ENABLED=true
KRAFT_LOTTO_SCHEDULER_LOCK_AT_MOST_FOR=PT10M
KRAFT_LOTTO_SCHEDULER_LOCK_AT_LEAST_FOR=PT10S
KRAFT_COLLECT_AUTO_ENABLED=true
KRAFT_COLLECT_AUTO_ZONE=Asia/Seoul
KRAFT_COLLECT_AUTO_CRON_SATURDAY_21_10=0 10 21 ? * SAT
KRAFT_COLLECT_AUTO_CRON_SATURDAY_21_RETRY=0 20,40 21 ? * SAT
KRAFT_COLLECT_AUTO_CRON_SATURDAY_22_10=0 10 22 ? * SAT
KRAFT_COLLECT_AUTO_CRON_SUNDAY_06_10=0 10 6 ? * SUN
KRAFT_COLLECT_AUTO_CRON_DAILY_09_00=0 0 9 * * *

# --- Recommend engine / rate limit ---
KRAFT_RECOMMEND_MAX_ATTEMPTS=5000
KRAFT_RECOMMEND_RULE_BIRTHDAY_THRESHOLD=31
KRAFT_RECOMMEND_RULE_LONG_RUN_THRESHOLD=5
KRAFT_RECOMMEND_RULE_DECADE_THRESHOLD=5
KRAFT_RECOMMEND_RATE_LIMIT_MAX_REQUESTS=30
KRAFT_RECOMMEND_RATE_LIMIT_WINDOW_SECONDS=60
KRAFT_COLLECT_RATE_LIMIT_MAX_REQUESTS=10
KRAFT_COLLECT_RATE_LIMIT_WINDOW_SECONDS=300

# --- Optional Redis rate-limit ---
# Redis rate-limit은 기본 비활성입니다.
# 기본값은 false이며, 이 값이면 로컬 실행과 docker-compose 기본 실행 모두 Redis 없이 동작합니다.
# 현재 docker-compose.yml에는 Redis 서비스가 없으므로 로컬/기본 구성에서는 false를 유지하세요.
# true로 활성화하려면 운영자가 별도 Redis 인프라를 준비하고 애플리케이션의 Redis 접속 설정을 함께 제공해야 합니다.
KRAFT_RECOMMEND_RATE_LIMIT_REDIS_ENABLED=false
# Redis rate-limit 키 prefix입니다. Redis 기능을 활성화할 때만 사용됩니다.
KRAFT_RECOMMEND_RATE_LIMIT_REDIS_KEY_PREFIX=kraft:rate-limit

# --- Tracing ---
KRAFT_TRACING_ENABLED=false
KRAFT_TRACING_SAMPLING_PROBABILITY=1.0
KRAFT_OTLP_TRACING_ENDPOINT=http://localhost:4318/v1/traces

# --- Collect log retention ---
KRAFT_COLLECT_LOG_RETENTION_ENABLED=true
KRAFT_COLLECT_LOG_RETENTION_DAYS=90
KRAFT_COLLECT_LOG_RETENTION_CRON=0 30 3 * * *

# --- Logging ---
# docker-compose는 ./logs를 /app/logs에 bind mount합니다.
KRAFT_LOG_PATH=./logs

# --- Container healthcheck ---
KRAFT_HEALTHCHECK_URL=http://localhost:8080/actuator/health/readiness
KRAFT_HEALTHCHECK_TIMEOUT_SECONDS=3
