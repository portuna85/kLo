# ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ
#  KraftLotto ???м„ҚкјҚ и№ӮВҖ???м’—лөҶз”ұ?(еӘӣм’•м»» ?в‘Ҙм”Ә ?кҫЁмӨҲ?лҡҜм”Ә)
#  ?г…јм Ј йҚ®кҫЁ?еӘӣлҜӘ? .env жҝЎ?и№Ӯл“ӯк¶— ??п§ўкҫ©мҠҰ?лӘ„мҠӮ. .env ??git з•°л¶ҝмҹ» ?м’–мҮ….
#    cp .env.example .env
# ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ
# --- Spring profile (еӘӣм’•м»» ?м„ҚкјҚ?ВҖ local п§Қ??СҠмҠң) ---
SPRING_PROFILES_ACTIVE=local
# --- Docker Compose ports ---
KRAFT_APP_PORT=8080
KRAFT_DB_PORT=3306
# --- DB (?лӘ„л’Ә??'mariadb' = docker-compose ?м’•нү¬?г…»мұё) ---
KRAFT_DB_NAME=kraft_lotto
KRAFT_DB_URL=jdbc:mariadb://mariadb:3306/kraft_lotto?rewriteBatchedStatements=true&useUnicode=true&characterEncoding=utf8mb4&serverTimezone=Asia/Seoul&connectTimeout=3000
KRAFT_DB_USER=kraft
KRAFT_DB_PASSWORD=change-me
KRAFT_DB_ROOT_PASSWORD=change-me-root
# ?лӘ„л’Ә??OS ?лЁҜкҪҢ bootRun ?к№Ҷм‘қжҝЎ?п§һкіём ’ ?г…Ҫл»ҫ????mariadb ?м’•нү¬?г…»мұё??з§»м„‘мҶҡ???ВҖ?кіём—Ҝ?лҚҲл–Һ.
KRAFT_DB_LOCAL_HOST=localhost
# Docker Compose ??иҖҢв‘ҰлҖ’?лҢҖкј«?лЁҜкҪҢ ??еӘӣлҜӘм“Ј true жҝЎ?дәҢмҮұм—Ҝ?в‘ёл•І?? ?лӘ„л’Ә???г…Ҫл»ҫ?лЁҜкҪҢ??false/иӘҳлӘ„кҪ•???мўҺ?.
KRAFT_IN_CONTAINER=false
# --- ?лӘғ? ?мҲүл»ҫи№Ӯл“Ұн…’ API ---
# mock | real(=dhlottery)
KRAFT_API_CLIENT=mock
KRAFT_API_URL=https://www.dhlottery.co.kr/common.do
KRAFT_API_CONNECT_TIMEOUT_MS=2000
KRAFT_API_READ_TIMEOUT_MS=3000
KRAFT_API_MAX_RETRIES=2
KRAFT_API_RETRY_BACKOFF_MS=200
# --- ж„ҝВҖз”ұСҠмҳ„ API ---
# POST /api/winning-numbers/refresh ?лӘ„н…§ ??X-Kraft-Admin-Token ?г…»лң‘жҝЎ??кҫЁл––?в‘ёл•І??
KRAFT_ADMIN_API_TOKEN=change-me-admin-token
KRAFT_ADMIN_TOKEN_HEADER=X-Kraft-Admin-Token
# --- з•°л¶ҝмҝҮ ?л¶ҝмӯҠ ---
KRAFT_RECOMMEND_MAX_ATTEMPTS=5000
KRAFT_RECOMMEND_RATE_LIMIT_MAX_REQUESTS=30
KRAFT_RECOMMEND_RATE_LIMIT_WINDOW_SECONDS=60
KRAFT_RECOMMEND_RATE_LIMIT_REDIS_ENABLED=false
KRAFT_RECOMMEND_RATE_LIMIT_REDIS_KEY_PREFIX=kraft:rate-limit
KRAFT_TRACING_ENABLED=false
KRAFT_TRACING_SAMPLING_PROBABILITY=1.0
KRAFT_OTLP_TRACING_ENDPOINT=http://localhost:4318/v1/traces
KRAFT_COLLECT_LOG_RETENTION_ENABLED=true
KRAFT_COLLECT_LOG_RETENTION_DAYS=90
KRAFT_COLLECT_LOG_RETENTION_CRON=0 30 3 * * *`r`nKRAFT_LOTTO_SCHEDULER_LOCK_AT_MOST_FOR=PT10M`r`nKRAFT_LOTTO_SCHEDULER_LOCK_AT_LEAST_FOR=PT10S
# --- Logging ---
KRAFT_LOG_PATH=./logs
# --- Container healthcheck ---
KRAFT_HEALTHCHECK_URL=http://localhost:8080/actuator/health/readiness
KRAFT_HEALTHCHECK_TIMEOUT_SECONDS=3
