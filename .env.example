# ─────────────────────────────────────────────────────────────
#  KraftLotto — 환경 변수 템플릿 (개발 단일 프로파일)
#  실제 비밀값은 .env 로 복사 후 채우세요. .env 는 git 추적 제외.
#    cp .env.example .env
# ─────────────────────────────────────────────────────────────
# --- Spring profile (개발 환경은 local 만 사용) ---
SPRING_PROFILES_ACTIVE=local
# --- Docker Compose ports ---
KRAFT_APP_PORT=8080
KRAFT_DB_PORT=3306
# --- DB (호스트 'mariadb' = docker-compose 서비스명) ---
KRAFT_DB_NAME=kraft_lotto
KRAFT_DB_URL=jdbc:mariadb://mariadb:3306/kraft_lotto?rewriteBatchedStatements=true&useUnicode=true&characterEncoding=utf8mb4&serverTimezone=Asia/Seoul&connectTimeout=3000
KRAFT_DB_USER=kraft
KRAFT_DB_PASSWORD=change-me
KRAFT_DB_ROOT_PASSWORD=change-me-root
# 호스트 OS 에서 bootRun 등으로 직접 실행할 때 mariadb 서비스명을 치환할 대상입니다.
KRAFT_DB_LOCAL_HOST=localhost
# Docker Compose 는 컨테이너에서 이 값을 true 로 주입합니다. 호스트 실행에서는 false/미설정 유지.
KRAFT_IN_CONTAINER=false
# --- 외부 동행복권 API ---
# mock | real(=dhlottery)
KRAFT_API_CLIENT=mock
KRAFT_API_URL=https://www.dhlottery.co.kr/common.do
KRAFT_API_CONNECT_TIMEOUT_MS=2000
KRAFT_API_READ_TIMEOUT_MS=3000
KRAFT_API_MAX_RETRIES=2
KRAFT_API_RETRY_BACKOFF_MS=200
# --- 관리자 API ---
# POST /api/winning-numbers/refresh 호출 시 X-Kraft-Admin-Token 헤더로 전달합니다.
# 운영 배포 시 반드시 KRAFT_ADMIN_API_TOKEN을 GitHub Secrets에 등록해야 하며, .env에는 실제 토큰 값을 직접 입력하지 마세요.
KRAFT_ADMIN_API_TOKEN=change-me-admin-token
KRAFT_ADMIN_TOKEN_HEADER=X-Kraft-Admin-Token
# --- 추천 엔진 ---
KRAFT_RECOMMEND_MAX_ATTEMPTS=100000
KRAFT_RECOMMEND_RATE_LIMIT_MAX_REQUESTS=30
KRAFT_RECOMMEND_RATE_LIMIT_WINDOW_SECONDS=60
KRAFT_COLLECT_RATE_LIMIT_MAX_REQUESTS=10
KRAFT_COLLECT_RATE_LIMIT_WINDOW_SECONDS=300
# --- Logging ---
KRAFT_LOG_PATH=./logs
# --- Container healthcheck ---
KRAFT_HEALTHCHECK_URL=http://localhost:8080/actuator/health/readiness
KRAFT_HEALTHCHECK_TIMEOUT_SECONDS=3
