{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "checkJs": true,
    "allowJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "lib": ["ESNext", "DOM"],
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "src/main/resources/static/js/**/*.js",
    "src/test/js/**/*.js"
  ]
}
